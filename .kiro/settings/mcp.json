{
  "mcpServers": {
    "system-status": {
      "command": "node",
      "args": ["./system-status-mcp/index.js"],
      "env": {
        "VITE_OLLAMA_URL": "https://chat-api.retakt.cc",
        "VITE_SEARXNG_URL": "https://search-api.retakt.cc"
      },
      "disabled": false,
      "autoApprove": ["get_system_status", "check_service"]
    },
    "ai-tools-status": {
      "command": "node",
      "args": ["./ai-tools-mcp-server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "disabled": false,
      "autoApprove": ["get_ai_tools_status", "check_specific_tool"]
    }
  }
}