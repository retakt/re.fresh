# Terminal Server Configuration
# Copy this file to .env and configure for your environment

# Terminal server port
TERMINAL_PORT=3003

# CORS origin (use * for development, specific origin for production)
TERMINAL_CORS_ORIGIN=*

# Terminal password for authentication
TERMINAL_PASSWORD=admin123

# Supabase configuration (for JWT verification if needed in future)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# AI Status API
AI_STATUS_API_URL=http://localhost:3002

# Open Terminal API (for fallback commands)
OPEN_TERMINAL_URL=https://tmux.retakt.cc
OPEN_TERMINAL_API_KEY=your-api-key

# Monitoring configuration
MONITOR_INTERVAL=30
MONITOR_LOG_DIR=logs
MONITOR_LOG_MAX_LINES=2000

# Service URLs
OLLAMA_URL=https://chat-api.retakt.cc
SEARXNG_URL=https://search-api.retakt.cc
YOUTUBE_API_URL=https://yt.retakt.cc/api
WEATHER_API_URL=https://wttr.in
EXCHANGE_API_URL=https://open.er-api.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/terminal-server.log
