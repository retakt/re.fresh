# YouTube Downloader Admin Token
# Set this to the same token you configured in the YT backend .env
VITE_YT_ADMIN_TOKEN=your-admin-token-here

# Shared Live Terminal
# WebSocket URL for the terminal server (frontend)
VITE_TERMINAL_WS_URL=ws://localhost:3003

# Supabase JWT secret — used by the terminal server to verify auth tokens
# Find this in your Supabase project: Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Optional: terminal server port (defaults to 3003)
TERMINAL_PORT=3003

# Optional: allowed CORS origin for the terminal server (defaults to *)
TERMINAL_CORS_ORIGIN=http://localhost:5173
