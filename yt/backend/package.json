{
  "name": "yt-downloader-backend",
  "version": "1.0.0",
  "description": "Robust YouTube downloader API with BullMQ job queue",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/queue/worker.js",
    "dev": "nodemon src/server.js",
    "dev:worker": "nodemon src/queue/worker.js"
  },
  "keywords": ["youtube", "downloader", "yt-dlp", "bullmq", "express"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "latest",
    "bullmq": "latest",
    "ioredis": "latest",
    "ws": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express-rate-limit": "latest",
    "winston": "latest"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
